<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="form_rent_lease_report">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="text-center">
                    <br/>
                    <br/>
                    <h1>Rent/Lease Management PDF Report</h1>
                </div>
                <br/>
                <br/>
                <table class="table">
                    <tr>
                        <th>Property</th>
                        <th>From Date</th>
                        <th>To Date</th>
                        <th>State</th>
                        <th>Tenant</th>
                        <th>Owner</th>
                        <th>Type</th>
                        <th>Amount</th>
                    </tr>
                    <tr t-foreach="report" t-as="o">
                        <td>
                            <span t-esc="o['property']"/>
                        </td>
                        <td>
                            <span t-esc="o['start_date']"/>
                        </td>
                        <td>
                            <span t-esc="o['end_date']"/>
                        </td>
                        <td>
                            <span t-esc="o['state']"/>
                        </td>
                        <td>
                            <span t-esc="o['tenant']"/>
                        </td>
                        <td>
                            <span t-esc="o['owner']"/>
                        </td>
                        <td>
                            <span t-esc="o['type']"/>
                        </td>
                        <td>
                            <span t-esc="o['amount']"/>
                        </td>
                    </tr>
                </table>
            </t>
        </t>
    </template>
</odoo>
