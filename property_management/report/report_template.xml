<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="form_rent_lease_report">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="text-center">
                    <br/>
                    <br/>
                    <h1>Rent/Lease Management PDF Report</h1>
                </div>
                <br/>
                <div class="page">
                    <div class="oe_structure"/>
                    <t t-foreach="report" t-as="o">
                        <p>
                            Start Date :
                            <span t-esc="o['start_date']"/>
                        </p>
                        <p>
                            End Date :
                            <span t-esc="o['end_date']"/>
                        </p>
                        <t t-if="data['owner']">
                            <p>
                                Owner :
                                <span t-esc="data['owner']"/>
                            </p>
                        </t>
                    </t>
                </div>
                <br/>
                <table class="table">
                    <tr>
                        <th>Property</th>
                        <th>State</th>
                        <th>Tenant</th>
                        <th>Type</th>
                        <th>Amount</th>
                        <t t-if="not data['owner']">
                            <th>Owner</th>
                        </t>
                    </tr>
                    <tr t-foreach="report" t-as="o">
                        <td>
                            <span t-esc="o['property']"/>
                        </td>
                        <td>
                            <span t-esc="o['state']"/>
                        </td>
                        <td>
                            <span t-esc="o['tenant']"/>
                        </td>
                        <td>
                            <span t-esc="o['type']"/>
                        </td>
                        <td>
                            <span t-esc="o['amount']"/>
                        </td>
                        <t t-if="not data['owner']">
                            <td>
                                <span t-esc="o['owner']"/>
                            </td>
                        </t>


                    </tr>
                </table>
            </t>
        </t>
    </template>
</odoo>
