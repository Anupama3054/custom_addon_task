<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_property_management"
                model="ir.module.category">
            <field name="name">Property</field>
            <field name="sequence">5</field>
        </record>
        <record id="res_groups_privilege_property" model="res.groups.privilege">
            <field name="name">Property management</field>
            <field name="category_id"
                   ref="property_management.module_category_property_management"/>
        </record>
        <!-- user groups -->
        <record id="group_property_user" model="res.groups">
            <field name="name">Property User</field>
            <field name="privilege_id" ref="res_groups_privilege_property"/>
            <field name="implied_ids" eval="[(4,ref('base.group_user'))]"/>
        </record>
        <record id="group_property_manager" model="res.groups">
            <field name="name">Property Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_property"/>
            <field name="implied_ids" eval="[(4,ref('group_property_user'))]"/>
            <field name="user_ids"
                   eval="[(4,ref('base.user_root')),(4,ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>