<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paylate_email_template" model="mail.template">
        <field name="name">Pay Late email template</field>
        <field name="model">account.move</field>
        <field name="subject">Late Payment</field>
        <field name="email_from">{{user.email}}</field>
        <field name="use_default_to" eval="False"/>
        <field name="email_to">{{ctx.get('to_email')}}</field>
        <field name="model_id" ref="property_management.model_account_move"/>
        <field name="body_html" type="html">
            <div>
                <p>
                    Dear <t t-out="object.lease_id.tenant_id.name"/>,
                    <br/>
                    <br/>
                    This is to inform you that your payment is
                    overdue.Kindly
                    pay without delay.
                    <br/>
                    <br/>
                    Thank you
                </p>
            </div>
        </field>
    </record>
</odoo>























