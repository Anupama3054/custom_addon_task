<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="property_facility" model="ir.ui.view">
        <field name="name">property.facility</field>
        <field name="model">property.facilities</field>
        <field name="arch" type="xml">
            <list string="Facilities" editable="bottom">
                <field name="facilities"/>
            </list>
        </field>
    </record>

    <!--window action-->
    <record id="action_property_facility" model="ir.actions.act_window">
        <field name="name">Facilities</field>
        <field name="res_model">property.facilities</field>
        <field name="view_mode">list</field>
    </record>
</odoo>