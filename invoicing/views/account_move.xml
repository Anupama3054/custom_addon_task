<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="invoice_view_form" model="ir.ui.view">
        <field name="name">invoice_view_form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_fill_invoice_line" type="object"
                        string="Assign" class="oe_highlight"/>
            </xpath>
            <xpath expr="//field[@name='partner_shipping_id']"
                   position="before">
                <field name="transfer_id"/>
            </xpath>
        </field>
    </record>
</odoo>