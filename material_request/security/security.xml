<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_material_request"
                model="ir.module.category">
            <field name="name">Material Request</field>
            <field name="sequence">5</field>
        </record>
        <record id="res_groups_privilege_material_request"
                model="res.groups.privilege">
            <field name="name">Material Requisition</field>
            <field name="category_id"
                   ref="material_request.module_category_material_request"/>
        </record>

<!--         user groups -->
        <record id="group_requisition_user" model="res.groups">
            <field name="name">Requisition User</field>
            <field name="privilege_id"
                   ref="res_groups_privilege_material_request"/>
            <field name="implied_ids" eval="[(4,ref('base.group_user'))]"/>
        </record>

        <record id="group_requisition_manager" model="res.groups">
            <field name="name">Requisition Manager</field>
            <field name="privilege_id"
                   ref="res_groups_privilege_material_request"/>
        </record>

        <record id="group_requisition_head" model="res.groups">
            <field name="name">Requisition Head</field>
            <field name="privilege_id"
                   ref="res_groups_privilege_material_request"/>
        </record>
    </data>
</odoo>