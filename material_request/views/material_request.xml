<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORM VIEW -->
    <record id="material_request_form" model="ir.ui.view">
        <field name="name">Material Request Form</field>
        <field name="model">material.req.ref</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar"
                           options="{'clickable':0}"/>
                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            groups="material_request.group_requisition_user"
                            class="oe_highlight" invisible="status != 'Draft'"/>
                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            groups="material_request.group_requisition_manager,material_request.group_requisition_head"
                            class="oe_highlight"/>
                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            groups="material_request.group_requisition_head"
                            class="oe_highlight"
                            invisible="status == 'Rejected'"/>

                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_internal_transfers"
                                type="object" class="oe_stat_button">
                            <div class="o_stat_info">
                                <field name="internal_transfers_count"
                                       class="o_stat_value"/>
                                <span class="o_stat_text">Internal Transfers
                                </span>
                            </div>
                        </button>
                        <button name="action_open_po"
                                type="object" class="oe_stat_button">
                            <div class="o_stat_info">
                                <field name="po_count"
                                       class="o_stat_value"/>
                                <span class="o_stat_text">Purchase Orders
                                </span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <h1>
                            <field name="material_request_id" readonly="1"/>
                        </h1>
                    </group>
                    <group>
                        <group>
                            <field name="employee_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Order Lines">
                            <field name="line_ids">
                                <list string="Order Lines"
                                      editable="bottom">
                                    <field name="product_id"/>
                                    <field name="prod_source"/>
<!--                                    <field name="vendor_id"-->
<!--                                           widget="many2many_tags"/>-->
                                    <field name="location_id"
                                           domain="[('usage','=','internal')]"
                                           readonly="prod_source == 'Purchase Order'"/>
                                    <field name="location_dest_id"
                                           domain="[('usage','=','internal')]"
                                           readonly="prod_source == 'Purchase Order'"/>
                                    <field name="price_unit"/>
                                    <field name="product_qty"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <!--            List view-->

    <record id="material_request_list" model="ir.ui.view">
        <field name="name">Material Request List</field>
        <field name="model">material.req.ref</field>
        <field name="arch" type="xml">
            <list>
                <field name="material_request_id"/>
                <field name="employee_id"/>
                <field name="date"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>


    <!--window-->

    <record id="action_material_request" model="ir.actions.act_window">
        <field name="name">Requests</field>
        <field name="res_model">material.req.ref</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>create your first Request</p>
        </field>
    </record>
</odoo>
