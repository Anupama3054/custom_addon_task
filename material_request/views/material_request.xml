<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <odoo>
        <data>
            <!-- FORM VIEW -->
            <record id="material_request_form" model="ir.ui.view">
                <field name="name">Material Request Form</field>
                <field name="model">material.req.ref</field>
                <field name="arch" type="xml">
                    <form>
                        <sheet>
                            <group>
                            <group>
                                <field name="employee_id"/>
                            </group>
                            <group>
                                <field name="date"/>
                            </group>
                            </group>
                            <notebook>
                                <page string="Order Lines">
                                    <field name="line_ids">
                                        <list string="Order Lines"
                                              editable="bottom">
                                            <field name="product_id"/>
                                            <field name="prod_source"/>
                                            <field name="price_unit"/>
                                            <field name="product_qty"/>
                                        </list>
                                    </field>
                                </page>
                            </notebook>
                        </sheet>
                    </form>
                </field>
            </record>
        </data>
    </odoo>
    <!--window-->

    <record id="action_material_request" model="ir.actions.act_window">
        <field name="name">Requests</field>
        <field name="res_model">material.req.ref</field>
        <field name="view_mode">form</field>
        <field name="help" type="html">
            <p>create your first Request</p>
        </field>
    </record>
</odoo>
